*.sql
*.sql.gz
*.dump

# 环境变量
.env
.env.local

# 编辑器 / OS
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp

# Python
__pycache__/
*.pyc
.venv/
venv/

# 日志文件
*.log

# Claude Code 内部数据
.claude/

# 运行时状态文件
strategy_live_state.json
strategy_whale_state.json
strategy_live_trades.jsonl
