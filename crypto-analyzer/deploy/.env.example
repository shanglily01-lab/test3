# ============================================================
# 加密货币分析系统 - AWS 生产环境变量模板
# 用法: cp deploy/.env.example .env && 填入真实值
# 重要: .env 已在 .gitignore 中，切勿提交到 git
# ============================================================

# --------- 数据库 (AWS RDS 或 EC2 本地 MySQL) ---------
DB_HOST=localhost
DB_PORT=3306
DB_USER=crypto_user
DB_PASSWORD=REPLACE_ME_STRONG_PASSWORD
DB_NAME=binance-data

# --------- JWT 认证 (Web UI 登录) ---------
JWT_SECRET_KEY=REPLACE_ME_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --------- 交易所 API (Binance U本位合约) ---------
# 权限: 只勾 Enable Futures, 绑定 AWS EC2 出口 IP 白名单
BINANCE_API_KEY=REPLACE_ME
BINANCE_API_SECRET=REPLACE_ME

# --------- Gate.io (可选) ---------
GATE_API_KEY=
GATE_API_SECRET=

# --------- AI (Gemini, 用于 BTC 方向判断 + 策略生成) ---------
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-3-flash-preview

# --------- Telegram 通知 ---------
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# --------- 其他可选 API (保留占位, 不填不影响核心功能) ---------
CRYPTOPANIC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# --------- 运行模式开关 ---------
USE_V3_MODE=true
