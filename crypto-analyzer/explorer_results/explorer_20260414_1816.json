    "mode": "mtf_self",
    "hypothesis": "价格凸性衰减的增强版：观察“买压转换加速度”。如果1h价格还在涨，但“单位买压产生的梯度”在二阶导数上出现断崖式下跌，说明多头正在用透支的方式维持价格，崩塌在即。",
    "code": "def sig(cs1h, cs4h=None):\n    if not cs1h or not cs4h or len(cs1h) < 15 or len(cs4h) < 10:\n        return None\n\n    # 4h 宏观偏弱\n    if gradient(cs4h, 8) > -0.003: return None\n\n    # 转换率函数：梯度 / (买压偏离度)\n    def get_trans_rate(cs, n):\n        f = flux(cs, n)\n        return gradient(cs, n) / (f - 0.4 + 1e-9) # 0.4为买压基础摩擦值\n\n    rate_now = get_trans_rate(cs1h, 2)\n    rate_prev = get_trans_rate(cs1h, 5)\n\n    # 逻辑：价格在反弹，但买压转换效率不到之前的30%，呈现极强的凸性衰减\n    if gradient(cs1h, 2) > 0.001 and rate_now < rate_prev * 0.3:\n        if flux(cs1h, 2) < 0.53: # 即使买压看起来尚可，但效率已死\n            return \"SHORT\"\n    return None",
