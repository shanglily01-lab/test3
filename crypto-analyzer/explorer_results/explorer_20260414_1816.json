    "name": "NonLinearExhaustion",
    "mode": "mtf_self",
    "hypothesis": "利用非线性组合识别衰竭：定义‘购买力转换率’为(gradient/flux)。若该比例在短时间内出现负向偏离，而振幅(amplitude)在扩大，意味着市场进入了‘无效波动’阶段。",
    "code": "def sig(cs1h, cs4h=None):\n    if not cs1h or not cs4h or len(cs1h) < 15 or len(cs4h) < 10:\n        return None\n\n    # 1h 购买力转换效率\n    def get_conversion(cs, n):\n        f = flux(cs, n)\n        # 使用0.4作为买盘活跃基准，避免分母过小\n        return gradient(cs, n) / (f - 0.4 if f > 0.4 else 0.05)\n\n    conv_2 = get_conversion(cs1h, 2)\n    conv_8 = get_conversion(cs1h, 8)\n\n    # 4h下跌，1h反弹。如果短期转换率转负，或者跌破中期效率的20%\n    if gradient(cs4h, 8) < -0.006 and gradient(cs1h, 3) > 0.001:\n        # 此时振幅在放大(波动增加)，但转换效率急剧下降\n        if conv_2 < conv_8 * 0.2 and amplitude(cs1h, 2) > amplitude(cs1h, 8):\n            return \"SHORT\"\n    return None",
