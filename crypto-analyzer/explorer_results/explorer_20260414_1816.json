    "round": 5,
    "name": "InertialDragShort",
    "mode": "mtf_self",
    "hypothesis": "利用‘K线实体压缩’与‘二阶梯度加速度’的非线性组合。当4h宏观下跌时，如果1h价格反弹速度（梯度）尚存但实体占比急剧收缩至0.2以下，说明价格上涨已完全依赖于空头平仓的惯性，而非主动买盘的推进。",
    "code": "def sig(cs1h, cs4h=None):\n    if not cs1h or not cs4h or len(cs1h) < 10 or len(cs4h) < 8:\n        return None\n\n    # 1. 宏观弱势\n    if gradient(cs4h, 8) > -0.006: return None\n\n    # 2. 实体占比计算 (Body / Range)\n    def get_body_ratio(cs, n):\n        ratios = []\n        for i in range(1, n + 1):\n            r = cs[-i][\"high\"] - cs[-i][\"low\"]\n            b = abs(cs[-i][\"close\"] - cs[-i][\"open\"])\n            ratios.append(b / r if r > 0 else 0.5)\n        return sum(ratios) / n\n\n    br_short = get_body_ratio(cs1h, 2)\n    # 3. 逻辑：价格在涨但实体极小(虚涨) + 梯度开始减速\n    if gradient(cs1h, 2) > 0 and br_short < 0.22:\n        if gradient(cs1h, 2) < gradient(cs1h, 5) * 0.4:\n            return \"SHORT\"\n    return None",
