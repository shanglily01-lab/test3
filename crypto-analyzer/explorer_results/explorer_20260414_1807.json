  {
    "round": 2,
    "name": "WickSaturationShort",
    "mode": "mtf_self",
    "hypothesis": "在4h宏观下行中，1h反弹表现为“高影线低实体”，即上影线总和远超实体总和，说明每一段上涨都被高位的被动限价单（Passive Supply）瞬间吸收。",
    "code": "def sig(cs1h, cs4h=None):\n    if not cs1h or not cs4h or len(cs1h) < 5 or len(cs4h) < 5:\n        return None\n    \n    # 计算最近3根K线的上影线总和与实体总和\n    upper_wicks = sum([(cs1h[-i]['high'] - max(cs1h[-i]['open'], cs1h[-i]['close'])) for i in range(1, 4)])\n    bodies = sum([abs(cs1h[-i]['close'] - cs1h[-i]['open']) for i in range(1, 4)])\n    \n    # 4h宏观趋势看跌 (梯度 < -0.5%)\n    # 1h短期在反弹 (梯度 > 0.1%)\n    # 逻辑：上影线是实体的1.5倍以上，且买压flux掉下0.49\n    if gradient(cs4h, 4) < -0.005 and gradient(cs1h, 3) > 0.001:\n        if upper_wicks > (bodies * 1.5) and flux(cs1h, 2) < 0.49:\n            return \"SHORT\"\n    return None",
